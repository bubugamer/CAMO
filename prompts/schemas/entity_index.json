{
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "characters"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.2"
    },
    "characters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "character_type",
          "name",
          "description",
          "aliases",
          "titles",
          "identities",
          "source_segments"
        ],
        "properties": {
          "character_type": {
            "type": "string",
            "enum": [
              "fictional_person",
              "real_person",
              "group_persona",
              "virtual_persona",
              "unnamed_person",
              "unidentified_person"
            ]
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "titles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "identities": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "value"],
              "properties": {
                "type": {
                  "type": "string"
                },
                "value": {
                  "type": "string"
                }
              }
            }
          },
          "source_segments": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
