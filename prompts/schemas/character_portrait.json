{
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "character_core", "character_facet", "relationships", "events", "memories"],
  "$defs": {
    "relationship_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strength", "stance", "notes"],
      "properties": {
        "strength": { "type": "integer", "minimum": 0, "maximum": 100 },
        "stance": { "type": "string", "enum": ["positive", "neutral", "negative"] },
        "notes": { "type": "string" }
      }
    },
    "activation_range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_timeline_pos", "end_timeline_pos"],
      "properties": {
        "start_timeline_pos": { "type": "integer", "minimum": 1 },
        "end_timeline_pos": { "type": "integer", "minimum": 1 }
      }
    }
  },
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.2"
    },
    "character_core": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "trait_profile",
        "motivation_profile",
        "behavior_profile",
        "communication_profile",
        "constraint_profile"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "0.2"
        },
        "trait_profile": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "openness",
            "conscientiousness",
            "extraversion",
            "agreeableness",
            "neuroticism"
          ],
          "properties": {
            "openness": { "type": "integer", "minimum": 0, "maximum": 100 },
            "conscientiousness": { "type": "integer", "minimum": 0, "maximum": 100 },
            "extraversion": { "type": "integer", "minimum": 0, "maximum": 100 },
            "agreeableness": { "type": "integer", "minimum": 0, "maximum": 100 },
            "neuroticism": { "type": "integer", "minimum": 0, "maximum": 100 }
          }
        },
        "motivation_profile": {
          "type": "object",
          "additionalProperties": false,
          "required": ["primary", "secondary", "suppressed"],
          "properties": {
            "primary": {
              "type": "array",
              "minItems": 1,
              "maxItems": 2,
              "items": {
                "type": "string",
                "enum": [
                  "power",
                  "status",
                  "wealth",
                  "survival",
                  "affiliation",
                  "altruism",
                  "curiosity",
                  "mastery",
                  "freedom",
                  "revenge",
                  "order",
                  "pleasure",
                  "truth",
                  "loyalty",
                  "fairness",
                  "honor",
                  "efficiency"
                ]
              }
            },
            "secondary": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "power",
                  "status",
                  "wealth",
                  "survival",
                  "affiliation",
                  "altruism",
                  "curiosity",
                  "mastery",
                  "freedom",
                  "revenge",
                  "order",
                  "pleasure",
                  "truth",
                  "loyalty",
                  "fairness",
                  "honor",
                  "efficiency"
                ]
              }
            },
            "suppressed": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "power",
                  "status",
                  "wealth",
                  "survival",
                  "affiliation",
                  "altruism",
                  "curiosity",
                  "mastery",
                  "freedom",
                  "revenge",
                  "order",
                  "pleasure",
                  "truth",
                  "loyalty",
                  "fairness",
                  "honor",
                  "efficiency"
                ]
              }
            }
          }
        },
        "behavior_profile": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "conflict_style",
            "risk_preference",
            "decision_style",
            "dominance_style"
          ],
          "properties": {
            "conflict_style": {
              "type": "string",
              "enum": [
                "avoidant",
                "direct_confrontation",
                "indirect_control",
                "manipulative",
                "compliant"
              ]
            },
            "risk_preference": {
              "type": "string",
              "enum": [
                "low",
                "medium_low",
                "medium",
                "medium_high",
                "high"
              ]
            },
            "decision_style": {
              "type": "string",
              "enum": [
                "impulsive",
                "emotional",
                "deliberate",
                "strategic"
              ]
            },
            "dominance_style": {
              "type": "string",
              "enum": [
                "egalitarian",
                "hierarchical",
                "authoritative",
                "covert_control"
              ]
            }
          }
        },
        "communication_profile": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "tone",
            "directness",
            "emotional_expressiveness",
            "verbosity",
            "politeness"
          ],
          "properties": {
            "tone": {
              "type": "string",
              "enum": [
                "formal",
                "neutral",
                "casual",
                "aggressive"
              ]
            },
            "directness": {
              "type": "string",
              "enum": ["low", "medium", "high"]
            },
            "emotional_expressiveness": {
              "type": "string",
              "enum": ["low", "medium", "high"]
            },
            "verbosity": {
              "type": "string",
              "enum": ["low", "medium", "high"]
            },
            "politeness": {
              "type": "string",
              "enum": ["low", "medium", "high"]
            }
          }
        },
        "constraint_profile": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "knowledge_scope",
            "role_consistency",
            "forbidden_behaviors"
          ],
          "properties": {
            "knowledge_scope": {
              "type": "string",
              "enum": ["strict", "bounded", "open"]
            },
            "role_consistency": {
              "type": "string",
              "enum": ["strict", "medium", "loose"]
            },
            "forbidden_behaviors": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["namespace", "tag", "description"],
                "properties": {
                  "namespace": {
                    "type": "string",
                    "enum": ["meta", "style", "setting", "plot", "ethics", "custom"]
                  },
                  "tag": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "character_facet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "evidence_map",
        "biographical_notes",
        "temporal_snapshots",
        "extraction_meta"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "0.2"
        },
        "evidence_map": {
          "type": "object",
          "propertyNames": {
            "pattern": "^(trait_profile\\.(openness|conscientiousness|extraversion|agreeableness|neuroticism)|motivation_profile\\.(primary|secondary|suppressed)|behavior_profile\\.(conflict_style|risk_preference|decision_style|dominance_style)|communication_profile\\.(tone|directness|emotional_expressiveness|verbosity|politeness)|constraint_profile\\.(knowledge_scope|role_consistency|forbidden_behaviors))$"
          },
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["segment_ids", "excerpt", "confidence", "reasoning"],
              "properties": {
                "segment_ids": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string" }
                },
                "excerpt": { "type": "string" },
                "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
                "reasoning": { "type": "string" }
              }
            }
          }
        },
        "biographical_notes": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "appearance",
            "backstory",
            "signature_habits",
            "catchphrases"
          ],
          "properties": {
            "appearance": { "type": "string" },
            "backstory": { "type": "string" },
            "signature_habits": {
              "type": "array",
              "items": { "type": "string" }
            },
            "catchphrases": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "temporal_snapshots": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "snapshot_id",
              "period_label",
              "activation_range",
              "display_hint",
              "stage_summary",
              "known_facts",
              "unknown_facts",
              "profile_overrides",
              "notes"
            ],
            "properties": {
              "snapshot_id": { "type": "string" },
              "period_label": { "type": "string" },
              "activation_range": { "$ref": "#/$defs/activation_range" },
              "display_hint": {
                "type": "object",
                "additionalProperties": false,
                "required": ["primary", "secondary"],
                "properties": {
                  "primary": { "type": "string" },
                  "secondary": { "type": "string" }
                }
              },
              "stage_summary": { "type": "string" },
              "known_facts": {
                "type": "array",
                "items": { "type": "string" }
              },
              "unknown_facts": {
                "type": "array",
                "items": { "type": "string" }
              },
              "profile_overrides": { "type": "object" },
              "notes": { "type": "string" }
            }
          }
        },
        "extraction_meta": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "extracted_at",
            "source_texts",
            "reviewer_status",
            "reviewer_notes",
            "schema_version"
          ],
          "properties": {
            "extracted_at": { "type": "string" },
            "source_texts": {
              "type": "array",
              "items": { "type": "string" }
            },
            "reviewer_status": { "type": "string" },
            "reviewer_notes": { "type": "string" },
            "schema_version": {
              "type": "string",
              "const": "0.2"
            }
          }
        }
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schema_version",
          "source_id",
          "target_id",
          "relation_category",
          "relation_subtype",
          "public_state",
          "hidden_state",
          "timeline",
          "source_segments",
          "confidence"
        ],
        "properties": {
          "schema_version": {
            "type": "string",
            "const": "0.2"
          },
          "source_id": { "type": "string" },
          "target_id": { "type": "string" },
          "relation_category": {
            "type": "string",
            "enum": [
              "kinship",
              "mentorship",
              "affection",
              "dependence",
              "exploitation",
              "opposition",
              "alliance",
              "reverence",
              "hierarchy"
            ]
          },
          "relation_subtype": { "type": "string" },
          "public_state": { "$ref": "#/$defs/relationship_state" },
          "hidden_state": {
            "anyOf": [
              { "$ref": "#/$defs/relationship_state" },
              { "type": "null" }
            ]
          },
          "timeline": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "effective_range",
                "snapshot_id",
                "public_state",
                "hidden_state",
                "source_segments"
              ],
              "properties": {
                "effective_range": { "$ref": "#/$defs/activation_range" },
                "snapshot_id": { "type": "string" },
                "public_state": { "$ref": "#/$defs/relationship_state" },
                "hidden_state": {
                  "anyOf": [
                    { "$ref": "#/$defs/relationship_state" },
                    { "type": "null" }
                  ]
                },
                "source_segments": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          },
          "source_segments": {
            "type": "array",
            "items": { "type": "string" }
          },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schema_version",
          "title",
          "description",
          "timeline_pos",
          "participant_names",
          "location",
          "emotion_valence",
          "source_segments"
        ],
        "properties": {
          "schema_version": {
            "type": "string",
            "const": "0.2"
          },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "timeline_pos": { "type": "integer" },
          "participant_names": {
            "type": "array",
            "items": { "type": "string" }
          },
          "location": { "type": "string" },
          "emotion_valence": {
            "type": "string",
            "enum": ["positive", "neutral", "negative", "mixed"]
          },
          "source_segments": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "memories": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "schema_version",
          "memory_type",
          "salience",
          "recency",
          "content",
          "source_event_title",
          "related_character_names",
          "emotion_valence",
          "source_segments"
        ],
        "properties": {
          "schema_version": {
            "type": "string",
            "const": "0.2"
          },
          "memory_type": {
            "type": "string",
            "enum": ["profile", "episodic"]
          },
          "salience": { "type": "number", "minimum": 0, "maximum": 1 },
          "recency": { "type": "number", "minimum": 0, "maximum": 1 },
          "content": { "type": "string" },
          "source_event_title": { "type": "string" },
          "related_character_names": {
            "type": "array",
            "items": { "type": "string" }
          },
          "emotion_valence": {
            "type": "string",
            "enum": ["positive", "neutral", "negative", "mixed"]
          },
          "source_segments": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
